# ---- Auth.js (Next) ----
# Generate with:  npx auth secret
AUTH_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Required in production; leave unset locally.
# AUTH_URL="https://your-app.vercel.app"

# ---- The seam between Next and Python ----
# Any long random string. Both services must agree.
#   openssl rand -hex 32
INTERNAL_API_KEY="dev-internal-key-change-me"
# Set by docker-compose. Only needed here if you run the two services by hand.
# API_URL="http://localhost:8000"

# ---- Python service ----
# Set by docker-compose. Only needed if you run FastAPI outside Docker.
# DATABASE_URL="postgresql+psycopg://atoms:atoms@localhost:5432/atoms"

# ---- Model providers ----
# Provider API keys are configured per user in the app's Settings modal.
